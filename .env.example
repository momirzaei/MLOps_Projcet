# --- PostgreSQL (Docker, mapped to host port 5433) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=change_me_admin
POSTGRES_DB=retail_dwh

# owner user: used by dbt / gold loading
DWH_OWNER_USER=retail_owner
DWH_OWNER_PASSWORD=change_me_owner

# read-only user: the ONLY user Text-to-SQL will ever use
DWH_READONLY_USER=retail_readonly
DWH_READONLY_PASSWORD=change_me_readonly

# --- LLM API (Groq, OpenAI-compatible) ---
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=put_your_groq_key_here
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
